# Copy to `secrets.toml` in this folder (do not commit real secrets).
# Streamlit Cloud: paste equivalent keys in App Settings → Secrets.

ANTHROPIC_API_KEY = "sk-ant-api03-..."
PERPLEXITY_API_KEY = "pplx-..."

# Invite-only passwords (users enter one in sidebar "Client ID / Access Code").
# Option A — list:
APP_INVITE_CODES = ["SteepRock_Access", "invite-beta"]

# Option B — single code (uncomment instead of list):
# APP_INVITE_CODE = "my-single-invite"

# Optional: code that sees all clients' files in File Log (default EDGAR_ADMIN if unset).
# ADMIN_ACCESS_CODE = "EDGAR_ADMIN"
